      <aliases enabled='yes' />
      <column datatype='string' name='[Age]' role='dimension' type='nominal' />
      <column caption='Mean 18-35' datatype='integer' name='[Calculation_1615807108660961280]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Age] = &apos;18-35&apos; THEN [Weighted Mean] END' />
      </column>
      <column caption='Mean 60+' datatype='integer' name='[Calculation_1615807108662239233]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Age] = &apos;60+&apos; THEN [Weighted Mean] END' />
      </column>
      <column caption='Age Gap ' datatype='real' name='[Calculation_1615807108662706179]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(IF [Age] =&apos;18-35&apos; THEN[Weighted Mean] END)&#10;-&#10;AVG(IF [Age] =&apos;60+&apos; THEN[Weighted Mean] END)' />
      </column>
